{
  "name": "zoopibot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "agent-core:build": "yarn workspace @zootopiafresh/agent-core build",
    "agent-core:changeset": "changeset",
    "agent-core:version": "changeset version",
    "agent-core:pack": "node ./scripts/agent-core-pack-smoke.mjs --keep",
    "agent-core:smoke": "node ./scripts/agent-core-pack-smoke.mjs",
    "agent-core:release:check": "yarn agent-core:build && ./node_modules/.bin/tsc --noEmit && yarn test:conversation && yarn test:openclaw && npm run check --prefix playgrounds/moonwave-counselor && node ./scripts/agent-core-pack-smoke.mjs",
    "agent-core:publish": "changeset publish",
    "dev": "yarn agent-core:build && node ./scripts/run-with-openclaw.mjs yarn dev:app",
    "dev:app": "sh -c 'next dev -p ${PORT:-3000}'",
    "build": "yarn agent-core:build && next build",
    "start": "yarn agent-core:build && node ./scripts/run-with-openclaw.mjs yarn start:app",
    "start:app": "sh -c 'next start -p ${PORT:-3000}'",
    "test:conversation": "yarn agent-core:build && node --import tsx --test test/conversation-runtime.test.ts test/conversation-runtime-reply.test.ts test/conversation-spec.test.ts",
    "test:openclaw": "yarn agent-core:build && node --import tsx --test test/openclaw-client.test.ts test/openclaw-runner.test.mjs test/openclaw-shell.test.mjs",
    "test:openclaw:smoke": "node --import tsx --test test/openclaw-smoke.test.ts",
    "lint": "next lint",
    "db:seed": "tsx scripts/add-dictionaries.ts",
    "db:seed:dict": "tsx scripts/add-dictionaries.ts",
    "admin:create": "tsx scripts/create-admin.ts"
  },
  "prisma": {
    "seed": "tsx scripts/add-dictionaries.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "5.22.0",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-md-editor": "^4.0.11",
    "@zootopiafresh/agent-core": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "mysql2": "^3.16.0",
    "next": "14.2.15",
    "next-auth": "^4.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.54.2",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-is": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "openclaw": "^2026.3.8",
    "postcss": "^8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
